rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Tournaments: public read, admin write
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;

      match /participants/{userId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
      }

      match /results/{userId} {
        allow read: if true;
        allow write: if request.auth.token.admin == true;
      }
    }

    // Users: sirf apna data read kar sake, admin sab dekh sake
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth.uid == userId || request.auth.token.admin == true;

      // Wallet balance sirf Cloud Function update kare (security)
      allow update: if !('depositedBalance' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('winningBalance' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('payouts' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // Banners: public read
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }

    // Transactions: sirf apni dekhe
    match /transactions/{transactionId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || request.auth.token.admin == true);
      allow create, update: if false; // sirf Cloud Function
    }

    // Withdrawal requests
    match /withdrawalRequests/{requestId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || request.auth.token.admin == true);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth.token.admin == true;
    }

    // Reports
    match /reports/{reportId} {
      allow read: if request.auth.token.admin == true;
      allow create: if request.auth != null;
    }

    // Announcements: public read
    match /announcements/{annId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }

    // Game Modes (Earn screen grid - public read, admin write)
    match /gameModes/{gameModeId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }

    // Password Reset OTPs (Forgot Password flow)
    // Any logged-in user can create/verify their own OTP document.
    match /passwordResets/{otpId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;  // OTPs persist for audit
    }
  }
}
