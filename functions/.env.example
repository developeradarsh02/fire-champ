# Fire Champ - Cloud Functions env (DO NOT COMMIT)
# Password reset OTP emails ke liye Gmail SMTP credentials.
#
# Setup:
#  1. Google Account → Security → 2-Step Verification ON karo
#  2. Google Account → Security → App Passwords → "Mail" ke liye password generate karo
#  3. Neeche values bharo aur `firebase deploy --only functions` chalao
GMAIL_USER=your-app-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
